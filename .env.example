CHATWOOT_BASE_URL=https://app.chatwoot.com
CHATWOOT_API_TOKEN=replace-me
CHATWOOT_ENABLE_HUMAN_HANDOFF=false
CHATWOOT_HANDOFF_TEAM_ID=
CHATWOOT_HANDOFF_ASSIGNEE_ID=

EMBED_MODEL=mistral/mistral-embed
LLM_MODEL=mistral/mistral-large-latest
LLM_MODEL_MEDIUM=mistral/mistral-medium-latest
LLM_MODEL_SMALL=mistral/mistral-small-latest

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mastra

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=atajoai-default
QDRANT_VECTOR_SIZE=1024

MUNICIPALITY_NAME=Ayuntamiento
MUNICIPALITY_PHONE=010
MUNICIPALITY_SCHEDULE=lunes a viernes de 9:00 a 14:00
MUNICIPALITY_ADDRESS=Plaza Mayor, 1
MUNICIPALITY_WEBSITE=https://www.ayuntamiento.es
MUNICIPALITY_ELECTRONIC_OFFICE_URL=https://sede.ayuntamiento.es
MUNICIPALITY_CHANNEL=web
MUNICIPALITY_PREFERRED_LANGUAGE=Español

OUTBOUND_RESPONSE_STYLE=brief_structured
# Legacy alias supported for backward compatibility:
# WHATSAPP_RESPONSE_STYLE=brief_structured
