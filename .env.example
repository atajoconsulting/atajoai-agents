# =============================================================================
# AtajoAI Agents — Variables de entorno
# =============================================================================
# Copia este archivo a .env y rellena los valores.
# Las variables marcadas con [docker-compose] se inyectan automaticamente
# dentro de la red Docker; solo necesitas definirlas aqui si ejecutas
# los servicios fuera de Docker.
# =============================================================================

# -----------------------------------------------------------------------------
# Base de datos
# -----------------------------------------------------------------------------
# Password de PostgreSQL (usado por docker-compose para postgres y pgbouncer)
DB_PASSWORD=changeme

# Prisma + pg-boss — conexion via PgBouncer (transaction pooling)
# [docker-compose] se sobreescribe a postgresql://atajoai:${DB_PASSWORD}@pgbouncer:6432/atajoai
DATABASE_URL=postgresql://atajoai:changeme@localhost:6432/atajoai

# Mastra PostgresStore — conexion DIRECTA a PostgreSQL (necesita LISTEN/NOTIFY)
# [docker-compose] se sobreescribe a postgresql://atajoai:${DB_PASSWORD}@postgres:5432/atajoai
MASTRA_DATABASE_URL=postgresql://atajoai:changeme@localhost:5432/atajoai

# Redis — cache de configuracion con invalidacion instantanea
# [docker-compose] se sobreescribe a redis://redis:6379
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Seguridad y autenticacion
# -----------------------------------------------------------------------------
# Secreto para firmar sesiones de better-auth (min 32 caracteres)
BETTER_AUTH_SECRET=569b08e4374f95b91bd556772c075417d9faca23ec16c959d6a59fb73e3ccfd3

# URL publica del panel (usado por better-auth para callbacks)
BETTER_AUTH_URL=http://localhost:3000

# Clave AES-256-GCM para encriptar tokens sensibles en BD (exactamente 64 chars hex = 32 bytes)
ENCRYPTION_KEY=596da6279a2d93cef33c9e13ee64e4d8299f9385239a806a5da12952bc95a410

# Desactivar autenticacion para desarrollo/testing (true | false)
AUTH_DISABLED=true

# -----------------------------------------------------------------------------
# Almacenamiento S3 / MinIO
# -----------------------------------------------------------------------------
# Region AWS (obligatorio incluso con MinIO)
AWS_REGION=eu-west-1

# Endpoint S3 — apunta a MinIO en Docker, a AWS S3 real en produccion
# [docker-compose] se sobreescribe a http://minio:9000
AWS_ENDPOINT_URL_S3=http://localhost:9000

# Nombre del bucket (se crea automaticamente en MinIO)
S3_BUCKET=atajoai

# Credenciales S3 / MinIO
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# -----------------------------------------------------------------------------
# Modelos de IA (Mistral u otro proveedor compatible)
# -----------------------------------------------------------------------------
# API key del proveedor LLM
MISTRAL_API_KEY=

# Modelo de embeddings para vectorizacion de documentos
EMBED_MODEL=mistral-embed

# Modelo principal (respuestas al ciudadano)
LLM_MODEL=mistral-large-latest

# Modelo medio (tareas secundarias)
LLM_MODEL_MEDIUM=mistral-medium-latest

# Modelo ligero (clasificacion, traduccion)
LLM_MODEL_SMALL=mistral-small-latest

# -----------------------------------------------------------------------------
# Vector store (Qdrant)
# -----------------------------------------------------------------------------
# [docker-compose] se sobreescribe a http://qdrant:6333
QDRANT_URL=http://localhost:6333

# API key de Qdrant (recomendado en produccion, opcional en dev)
# QDRANT_API_KEY=

# Nombre de la coleccion de vectores
QDRANT_COLLECTION=default

# Dimension de los vectores (debe coincidir con el modelo de embeddings)
QDRANT_VECTOR_SIZE=1024

# -----------------------------------------------------------------------------
# Comunicacion interna entre servicios
# -----------------------------------------------------------------------------
# URL interna del servicio Mastra (solo accesible dentro de la red Docker)
# [docker-compose] se sobreescribe a http://agents:4111
MASTRA_INTERNAL_URL=http://localhost:4111

# -----------------------------------------------------------------------------
# Panel — configuracion Next.js
# -----------------------------------------------------------------------------
# Entorno Node.js
NODE_ENV=development

# URL publica de la aplicacion (opcional, para metadatos y links absolutos)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Seed del usuario admin inicial
# -----------------------------------------------------------------------------
# Usados por: pnpm --filter @atajoai/panel seed:admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme1234
SEED_ADMIN_NAME=Admin
