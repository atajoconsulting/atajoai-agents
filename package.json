{
  "name": "atajoai",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "pnpm -r --filter @atajoai/db build && pnpm -r --filter '!@atajoai/db' build",
    "dev:agents": "pnpm -r --filter @atajoai/agents dev",
    "dev:panel": "pnpm -r --filter @atajoai/panel dev",
    "db:migrate": "pnpm -r --filter @atajoai/db db:migrate",
    "db:push": "pnpm -r --filter @atajoai/db db:push",
    "db:studio": "pnpm -r --filter @atajoai/db db:studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  }
}
