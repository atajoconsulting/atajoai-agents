{
  "name": "atajoai",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "pnpm -r --filter @atajoai/shared build && pnpm -r --filter '!@atajoai/shared' build",
    "dev:agents": "dotenv -- pnpm -r --filter @atajoai/agents dev",
    "dev:panel": "dotenv -- pnpm -r --filter @atajoai/panel dev",
    "db:generate": "dotenv -- pnpm -r --filter @atajoai/shared db:generate",
    "db:migrate": "dotenv -- pnpm -r --filter @atajoai/shared db:migrate",
    "db:push": "dotenv -- pnpm -r --filter @atajoai/shared db:push",
    "db:studio": "dotenv -- pnpm -r --filter @atajoai/shared db:studio",
    "seed:admin": "dotenv -- pnpm -r --filter @atajoai/panel seed:admin"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "msw"
    ]
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "shadcn": "^4.1.2",
    "tsx": "^4.21.0"
  }
}
