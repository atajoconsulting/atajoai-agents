generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["app"]
}

model AppConfig {
  id                Int      @id @default(1)
  orgName           String   @default("Ayuntamiento") @map("org_name")
  orgPhone          String?  @default("010") @map("org_phone")
  orgSchedule       String?  @default("lunes a viernes de 9:00 a 14:00") @map("org_schedule")
  orgAddress        String?  @default("Plaza Mayor, 1") @map("org_address")
  orgWebsite        String?  @default("https://www.ayuntamiento.es") @map("org_website")
  orgEOffice        String?  @map("org_e_office")
  preferredLang     String   @default("es") @map("preferred_lang")
  channel           String   @default("whatsapp")
  responseStyle     String   @default("brief_structured") @map("response_style")
  customInstructions String? @map("custom_instructions")
  greetingMessage   String?  @map("greeting_message")
  outOfScopeMessage String?  @map("out_of_scope_message")
  llmModel          String?  @map("llm_model")
  llmModelMedium    String?  @map("llm_model_medium")
  llmModelSmall     String?  @map("llm_model_small")
  embedModel        String?  @map("embed_model")
  retrievalTopK     Int      @default(12) @map("retrieval_top_k")
  retrievalFinalK   Int      @default(4) @map("retrieval_final_k")
  chatwootBaseUrl   String?  @map("chatwoot_base_url")
  chatwootApiToken  String?  @map("chatwoot_api_token")
  enableHandoff     Boolean  @default(false) @map("enable_handoff")
  handoffTeamId     Int?     @map("handoff_team_id")
  handoffAssigneeId Int?     @map("handoff_assignee_id")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("app_config")
  @@schema("app")
}

model IndexedDocument {
  id           String    @id @default(uuid())
  source       String
  sourceType   String    @map("source_type")
  title        String?
  status       String    @default("pending")
  errorMessage String?   @map("error_message")
  chunkCount   Int       @default(0) @map("chunk_count")
  contentHash  String?   @map("content_hash")
  s3Key        String?   @map("s3_key")
  indexedAt    DateTime? @map("indexed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("indexed_documents")
  @@schema("app")
}

// better-auth tables (generated by `npx auth generate`)

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @map("email_verified")
  image         String?
  role          String    @default("viewer")
  banned        Boolean?
  banReason     String?   @map("ban_reason")
  banExpires    DateTime? @map("ban_expires")
  createdAt     DateTime  @map("created_at")
  updatedAt     DateTime  @map("updated_at")
  sessions      Session[]
  accounts      Account[]

  @@map("user")
  @@schema("app")
}

model Session {
  id             String   @id
  expiresAt      DateTime @map("expires_at")
  token          String   @unique
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  userId         String   @map("user_id")
  impersonatedBy String?  @map("impersonated_by")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
  @@schema("app")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @map("created_at")
  updatedAt             DateTime  @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
  @@schema("app")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @map("created_at")
  updatedAt  DateTime? @map("updated_at")

  @@map("verification")
  @@schema("app")
}
